# Configuracao base para maquina dedicada Windows 11 - IP_DO_NOVO_SERVIDOR
# Copie este arquivo para .env na maquina de implantacao e troque todas as senhas/chaves antes de iniciar.

POSTGRES_USER=hidrometros_user
POSTGRES_PASSWORD=troque-por-senha-forte-do-banco
POSTGRES_DB=hidrometros_db

SECRET_KEY=troque-por-chave-aleatoria-com-64-caracteres-ou-mais
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ACTIVITY_UPDATE_SECONDS=60
PASSWORD_MIN_LENGTH=12

APP_NAME=Sistema GMF - Controle de Hidrometros
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=False
APP_TIMEZONE=America/Sao_Paulo

# Recomendado para implantacao empresarial: HTTPS.
# Se ainda for usar somente HTTP interno temporariamente, ajuste com cuidado.
COOKIE_SECURE=True
COOKIE_SAMESITE=strict
FORCE_HTTPS=True
ALLOWED_HOSTS=IP_DO_NOVO_SERVIDOR,localhost,127.0.0.1

FAILED_LOGIN_WINDOW_SECONDS=900
FAILED_LOGIN_MAX_ATTEMPTS=5
FAILED_LOGIN_LOCKOUT_SECONDS=900
SUSPICIOUS_OPERATION_WINDOW_SECONDS=60
SUSPICIOUS_OPERATION_MAX_PER_WINDOW=35
HARD_OPERATION_MAX_PER_WINDOW=80

DB_POOL_SIZE=30
DB_MAX_OVERFLOW=15
DB_POOL_RECYCLE_SECONDS=1800

# Preencha apenas no primeiro start com banco vazio. Depois remova ou deixe vazio.
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

BACKUP_STATUS=Configurado
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400
TLS_CERT_PATH=./certs/fullchain.pem
TLS_KEY_PATH=./certs/privkey.pem
LOG_LEVEL=INFO
READ_ONLY_MODE=False
